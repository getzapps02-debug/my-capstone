{
  "name": "@workspace/database",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate": "drizzle-kit migrate --config ../../drizzle.config.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@types/node": "^24",
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.7",
    "eslint": "^10",
    "globals": "^17",
    "typescript": "~6",
    "typescript-eslint": "^8",
    "vitest": "^4.1.0"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "development": "./src/schema/index.ts",
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    }
  }
}
